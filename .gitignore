.pnp.*
.pnp.cjs

# Env and secrets (do not commit)
.env
.env.local
.env*.local
!.env.example

# Uploads (server-generated, do not commit)
nextjs-project/public/uploads/

# Build and output
.next/
out/
build/
dist/
*.tsbuildinfo
# Tailwind/PostCSS compiled output (generated)
output.css
**/public/output.css

# Logs and debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

