# Prisma (generated client lives in node_modules / custom output)
# prisma/migrations/ — commit; .prisma/ — ignore if present
.prisma/
.worktrees/
*.prisma.backup
*.config.ts.bak

# DB dumps and local SQL artifacts (do not commit)
*.dump
*.sql
!prisma/migrations/**/*.sql
!**/prisma/migrations/**/*.sql
