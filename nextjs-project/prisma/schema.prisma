generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                                   String            @id @default(cuid())
  tildaUid                             String            @unique
  brand                                String?
  sku                                  String?
  mark                                 String?
  category                             String?
  title                                String
  description                          String?
  text                                 String?
  photo                                String?
  price                                Float
  quantity                             Int?
  priceOld                             Float?
  editions                             String?
  modifications                        String?
  externalId                           String?
  parentUid                            String?
  characteristicsNutrition100g         String?
  characteristicsKkal                  String?
  characteristicsContraindications     String?
  characteristicsShelfLife             String?
  characteristicsShelfLife2            String?
  characteristicsNutrition100gProduct  String?
  characteristicsEnergyValue100g       String?
  characteristicsNutrition100g2        String?
  characteristicsNutritionPerPortion5g String?
  characteristicsComposition           String?
  characteristicsKkal100gDailyDose     String?
  characteristicsFormulation           String?
  characteristicsCalorie               String?
  characteristicsFlacon200ml           String?
  characteristicsStorage               String?
  /// Вес в граммах (для СДЭК и расчёта доставки)
  weight                               Int?
  /// Длина в мм (для СДЭК: L)
  length                               Int?
  /// Ширина в мм (для СДЭК: W)
  width                                Int?
  /// Высота в мм (для СДЭК: H)
  height                               Int?
  seoTitle                             String?
  seoDescr                             String?
  seoKeywords                          String?
  fbTitle                              String?
  fbDescr                              String?
  tab1                                 String?
  tab2                                 String?
  tab3                                 String?
  tab4                                 String?
  /// Черновик: скрыть товар из клиентского каталога
  isDraft                              Boolean           @default(false)
  createdAt                            DateTime          @default(now())
  updatedAt                            DateTime          @updatedAt
  slug                                 String?           @unique
  tab1Title                            String?
  tab2Title                            String?
  tab3Title                            String?
  tab4Title                            String?
  /// Упорядоченный список URL изображений галереи (первое = основное)
  photos                               Json?
  /// Цена при применении промокода (если задана — используется для строки заказа при скидке)
  discountPrice                        Float?
  /// Участвует в скидке по промокоду (Rule: скидка применяется только к eligible и не к «уже по акции»)
  isPromoEligible                      Boolean           @default(true)
  /// Разрешить предзаказ при нулевом остатке
  isPreorderEnabled                    Boolean           @default(false)
  cartItems                            CartItem[]
  orderItems                           OrderItem[]
  categories                           ProductCategory[]
  quickOrders                          QuickOrder[]
  giftPromotions                       GiftPromotion[]

  @@index([slug])
  @@index([createdAt])
  @@index([tildaUid])
  // Индексы для каталога/поиска: ускоряют частые фильтры (не меняют бизнес-логику).
  @@index([isDraft, createdAt])
  @@index([isDraft, brand])
  @@index([isDraft, price, createdAt])
  @@index([isDraft, priceOld])
  @@index([isDraft, title, createdAt])
}

model Category {
  id                    String            @id @default(cuid())
  title                 String
  slug                  String            @unique
  image                 String?
  sortOrder             Int?
  /// Показывать категорию в блоке «Разделы каталога» на главной и в каталоге
  showInCategoriesBlock Boolean           @default(true)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  parentId              String?
  parent                Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children              Category[]        @relation("CategoryHierarchy")
  products              ProductCategory[]

  @@index([parentId])
  @@index([showInCategoriesBlock, sortOrder])
}

model ProductCategory {
  productId  String
  categoryId String
  /// Порядок товара внутри конкретной категории (для админки)
  sortOrder  Int?
  category   Category @relation(fields: [categoryId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@id([productId, categoryId])
}

model CartItem {
  id        String   @id @default(cuid())
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
}

model OrderItem {
  id              String         @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  price           Float
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  isGift          Boolean        @default(false)
  giftPromotionId String?
  order           Order          @relation(fields: [orderId], references: [id])
  product         Product        @relation(fields: [productId], references: [id])
  giftPromotion   GiftPromotion? @relation(fields: [giftPromotionId], references: [id])
}

model Order {
  id                  String        @id @default(cuid())
  userId              String?
  total               Float
  /// Сумма скидки по промокоду (для расчёта дохода партнёра от скидок)
  promoDiscountAmount Float?
  status              String        @default("pending")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  promoCodeId         String?
  /// * ID платежа ЮKassa (для связки с webhook и return_url)
  yookassaPaymentId   String?       @unique
  /// UUID заказа в СДЭК после успешного создания
  cdekOrderUuid       String?       @unique
  /// Последнее сообщение об ошибке СДЭК (для админки и повтора)
  cdekOrderError      String?
  /// Трек-номер СДЭК (если предоставлен)
  cdekTrackNumber     String?
  /// Дата мягкого удаления заказа (корзина). null = активен
  deletedAt           DateTime?
  promoCode           PromoCode?    @relation(fields: [promoCodeId], references: [id])
  user                User?         @relation(fields: [userId], references: [id])
  items               OrderItem[]
  shippingInfo        ShippingInfo?

  @@index([status])
  @@index([userId, createdAt])
  @@index([deletedAt, createdAt])
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  password                 String
  /// Имя
  name                     String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  role                     Role                      @default(USER)
  /// Получать тех. алерты (VPS/инфраструктура). Opt-in, только для ADMIN.
  infraAlertsEnabled       Boolean                   @default(false)
  mustChangePassword       Boolean                   @default(false)
  /// Фамилия
  lastName                 String?
  /// Телефон (для связи и отображения в профиле)
  phone                    String?
  /// Ящик для уведомлений о заказах (если задан — письма идут сюда, иначе на email)
  notificationEmail        String?
  /// Включена ли двухфакторная аутентификация
  twoFactorEnabled         Boolean                   @default(false)
  /// Способ 2FA: 'email' | 'totp'
  twoFactorMethod          String?
  /// Секрет TOTP (зашифрован), только при method = totp
  totpSecretEncrypted      String?
  /// Дата подтверждения email (null = не подтвержден)
  emailVerifiedAt          DateTime?
  /// Дата и время последнего входа в систему
  lastLoginAt              DateTime?
  /// База расчёта дохода партнёра: order_total | discount_amount (только для role PARTNER)
  partnerIncomeBase        String?
  emailVerificationTokens  EmailVerificationToken[]
  orders                   Order[]
  partnerPromoCodes        PartnerPromoCode[]
  passwordResetTokens      PasswordResetToken[]
  setInitialPasswordTokens SetInitialPasswordToken[]
  telegramLinkCodes        TelegramLinkCode[]
  telegramWhitelist        TelegramWhitelist?
  twoFactorGrants          TwoFactorGrant[]
  twoFactorPending         TwoFactorPending?
  addresses                UserAddress[]
}

model UserAddress {
  id             String   @id @default(cuid())
  userId         String
  label          String
  city           String
  postalCode     String?
  addressLine    String
  /// 'cdek_pvz' | 'cdek_door'
  deliveryMethod String
  cdekCityCode   Int
  cdekPvzCode    String?
  street         String?
  house          String?
  apartment      String?
  entrance       String?
  floor          String?
  intercom       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

/// Вайтлист Telegram: какой админ привязал какой Telegram ID для уведомлений
model TelegramWhitelist {
  id             String   @id @default(cuid())
  userId         String   @unique
  telegramUserId String   @unique
  linkedAt       DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([telegramUserId])
}

/// Одноразовые коды привязки Telegram (срок жизни 5–10 мин)
model TelegramLinkCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Токен завершения регистрации: ссылка + 6-значный код на почту. Одноразовый, с ограничением по времени.
model SetInitialPasswordToken {
  id                 String    @id @default(cuid())
  userId             String
  tokenHash          String
  expiresAt          DateTime
  usedAt             DateTime?
  emailCodeHash      String?
  emailCodeExpiresAt DateTime?
  codeVerifiedAt     DateTime?
  createdAt          DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Ожидание ввода кода 2FA после успешной проверки пароля
model TwoFactorPending {
  id                 String    @id @default(cuid())
  userId             String    @unique
  tokenHash          String
  expiresAt          DateTime
  emailCodeHash      String?
  emailCodeExpiresAt DateTime?
  createdAt          DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Одноразовый grant для завершения входа после успешной проверки 2FA
model TwoFactorGrant {
  id        String    @id @default(cuid())
  userId    String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ShippingInfo {
  id             String   @id @default(cuid())
  orderId        String   @unique
  fullName       String
  phone          String
  email          String
  address        String
  city           String
  zipCode        String
  country        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  /// 'cdek_pvz' | 'cdek_door' | null
  deliveryMethod String?
  /// Код города СДЭК получателя
  cdekCityCode   Int?
  /// Код ПВЗ (для cdek_pvz)
  cdekPvzCode    String?
  /// Код тарифа СДЭК (136, 139, 234 и т.д.)
  cdekTariffCode Int?
  /// Адрес до двери (структурированный)
  street         String?
  house          String?
  apartment      String?
  entrance       String?
  floor          String?
  intercom       String?
  order          Order    @relation(fields: [orderId], references: [id])
}

model Post {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  content      Json
  previewImage String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  excerpt      String?
  type         String   @default("news")

  @@index([published, type, createdAt])
}

/// Поисковые запросы каталога без выдачи (для доработки ассортимента и редиректов).
model CatalogSearchZeroHit {
  id        String   @id @default(cuid())
  query     String
  path      String   @default("/catalog")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([query])
}

/// SEO-хабы: кластерные страницы со ссылками на товары.
model SeoHub {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  excerpt       String?
  content       Json
  productSlugs  String[] @default([])
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([published, slug])
}

model PromoCode {
  id                String            @id @default(cuid())
  code              String            @unique
  discountType      String
  discountValue     Float
  isActive          Boolean           @default(true)
  usageLimit        Int?
  usedCount         Int               @default(0)
  validFrom         DateTime?
  validTo           DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  orders            Order[]
  partnerAssignment PartnerPromoCode?
}

model GiftPromotion {
  id                           String      @id @default(cuid())
  title                        String
  status                       String      @default("enabled")
  validFrom                    DateTime?
  validTo                      DateTime?
  giftProductId                String
  triggerType                  String
  triggerProductId             String?
  triggerProductMinQty         Int?
  minCartTotal                 Float?
  cartTotalCalculationMode     String?
  giftQuantityMode             String
  maxGiftsPerOrder             Int?
  promoProductInteractionMode  String?
  promoCodeInteractionMode     String?
  autoRemoveWhenConditionFails Boolean     @default(true)
  userCanRemoveGiftManually    Boolean     @default(false)
  showOnSite                   Boolean     @default(false)
  siteTitle                    String?
  siteDescription              String?
  coverImage                   String?
  createdAt                    DateTime    @default(now())
  updatedAt                    DateTime    @updatedAt
  giftProduct                  Product     @relation(fields: [giftProductId], references: [id])
  orderItems                   OrderItem[]
}

/// Связь партнёр–промокод: один промокод привязан не более чем к одному партнёру; процент дохода по промокоду.
model PartnerPromoCode {
  id                String    @id @default(cuid())
  userId            String
  promoCodeId       String    @unique
  commissionPercent Float
  createdAt         DateTime  @default(now())
  promoCode         PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PartnershipLead {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  role        String?
  socialLinks String?
  message     String?
  createdAt   DateTime @default(now())
}

/// Глобальный FAQ для страницы /faq.
model Faq {
  id          String   @id @default(cuid())
  question    String
  answer      String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, sortOrder])
}

/// Быстрые заявки "Купить в 1 клик".
model QuickOrder {
  id        String   @id @default(cuid())
  name      String?
  phone     String
  comment   String?
  productId String
  quantity  Int      @default(1)
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@index([status, createdAt])
  @@index([productId, createdAt])
}

model ContentBlock {
  id          String   @id @default(cuid())
  /// Идентификатор страницы: 'home', 'about', 'contacts', 'footer' и т.п.
  page        String
  /// Ключ блока: 'hero.badge', 'hero.title', 'home.news.subtitle' и т.п.
  key         String
  /// Человекочитаемое название для админки
  label       String
  /// Тип блока: 'short' | 'rich'
  type        String
  /// Короткий текст (для type = 'short')
  text        String?
  /// Rich-text содержимое в формате TipTap JSON (для type = 'rich')
  richJson    Json?
  /// Токен цвета Tailwind / дизайн-системы
  colorToken  String?
  /// Вариант шрифта / семейство (sans, display, script)
  fontVariant String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  /// Жирность шрифта: thin, light, normal, medium, semibold, bold, extrabold
  fontWeight  String?

  @@unique([page, key])
}

model SitePopup {
  id               String   @id @default(cuid())
  title            String
  isEnabled        Boolean  @default(false)
  richJson         Json?
  imageUrl         String?
  ctaLabel         String?
  ctaUrl           String?
  delaySeconds     Int      @default(5)
  hideForDays      Int      @default(7)
  autoCloseSeconds Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Настройки сайта (ключ-значение): СДЭК, ЮKassa, контакты и т.д.
model SiteSetting {
  key   String @id
  value String
}

/// Отзывы с формы на странице /otzyvy: имя автора, ссылка на профиль в соцсети, текст, опциональное фото. На сайте показываются только со статусом APPROVED.
model Review {
  id         String       @id @default(cuid())
  authorName String
  socialLink String?
  text       String
  imageUrl   String?
  createdAt  DateTime     @default(now())
  status     ReviewStatus @default(PENDING)

  @@index([status])
  @@index([status, createdAt])
}

/// Заявки/лиды, импортированные из Тильды (CSV). Только нужные столбцы: Email, Name, Phone, Date, tranid, Input, Input_2, Комментарии, Адрес_доставки, Отзыв, Доставка, Промокод.
model TildaLead {
  id              String   @id @default(cuid())
  email           String?
  name            String?
  phone           String?
  tildaDate       DateTime
  tildaTranId     String   @unique
  input           String?
  input2          String?
  comment         String?
  deliveryAddress String?
  review          String?
  delivery        String?
  promoCode       String?
  createdAt       DateTime @default(now())

  @@index([tildaDate])
  @@index([email])
}

/// Редиректы со старых URL (Tilda и др.) на текущий сайт. statusCode: 301 (по умолчанию), 302, 307, 308.
model Redirect {
  id          String   @id @default(cuid())
  /// Путь-источник (например /page12345), без query
  sourcePath  String   @unique
  /// Куда редиректить (например / или /product/slug)
  destination String
  /// 301 | 302 | 307 | 308
  statusCode  Int      @default(301)
  /// PRODUCT | PAGE | CUSTOM — для привязки к сущности в админке
  entityType  String?
  /// id товара или slug страницы
  entityId    String?
  /// Комментарий (старый URL с Тильды и т.д.)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sourcePath])
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  occurredAt DateTime           @default(now())
  userId     String?
  sessionId  String?
  anonId     String?
  type       AnalyticsEventType
  path       String
  pageTitle  String?
  meta       Json?
  ipHash     String?
  userAgent  String?

  @@index([occurredAt])
  @@index([type, occurredAt])
  @@index([path, occurredAt])
  @@index([sessionId, occurredAt])
}

model DailyTrafficStats {
  id        String   @id @default(cuid())
  date      DateTime
  path      String?
  pageViews Int
  sessions  Int
  users     Int?
  clicks    Int

  @@unique([date, path])
}

/// Сводка PAGE_VIEW по типу устройства за календарный день (устойчива к удалению сырых AnalyticsEvent).
model DailyDeviceStats {
  id       String   @id @default(cuid())
  date     DateTime
  desktop  Int      @default(0)
  mobile   Int      @default(0)
  tablet   Int      @default(0)
  /// События без meta.deviceType или с неизвестным значением
  unknown  Int      @default(0)

  @@unique([date])
  @@index([date])
}

model DailyFunnelStats {
  id               String     @id @default(cuid())
  date             DateTime
  step             FunnelStep
  count            Int
  conversionToNext Float?

  @@unique([date, step])
}

enum Role {
  USER
  WRITER
  ADMIN
  PARTNER
}

/// Статус модерации отзыва: ожидает модерации, одобрен (показывается на сайте), отклонён.
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AnalyticsEventType {
  PAGE_VIEW
  CLICK
  CART_ADD
  CHECKOUT_START
  ORDER_CREATED
}

enum FunnelStep {
  PAGE_VIEW
  CART_ADD
  CHECKOUT_START
  ORDER_CREATED
}
