# =============================================================================
# Inner Health — переменные окружения для деплоя и разработки
# Скопируйте в .env.local и заполните значения. Не коммитьте .env.local.
# =============================================================================

# --- Обязательные для работы приложения ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
NEXTAUTH_SECRET="<минимум 32 символа, сгенерируйте: openssl rand -base64 32>"
NEXTAUTH_URL="https://innerhealth.ru"

# Публичный URL сайта по умолчанию
NEXT_PUBLIC_SITE_URL="https://innerhealth.ru"
# Явные URL брендов для multi-storefront окружения
# NEXT_PUBLIC_INNER_SITE_URL="https://innerhealth.ru"
# NEXT_PUBLIC_SPRINT_POWER_SITE_URL="https://sprint-power.ru"

# Постобработка изображений товара (catalog + product page):
# contain-safe (по умолчанию, не режет низ), cover-top (старое), cover-crop-center (агрессивный кроп)
# NEXT_PUBLIC_PRODUCT_IMAGE_POSTPROCESS_MODE="contain-safe"

# Верификация сайта в Яндекс.Вебмастере (мета-тег verification)
# NEXT_PUBLIC_YANDEX_VERIFICATION=""

# Яндекс.Метрика: ID счётчика для reachGoal (пустой поиск в каталоге и др.)
# NEXT_PUBLIC_YM_COUNTER_ID=""

# Соль для хеширования IP при логировании пустого поиска (опционально)
# ZERO_HIT_RATE_SALT=""

# Секретный путь к админке (по умолчанию /admin; задайте свой для безопасности)
ADMIN_SECRET_PATH="admin-panel"

# Ключ шифрования настроек в БД (SiteSetting), base64 для 32 байт: openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY="<base64-32-byte-key>"

# Нестандартный корень проекта на сервере (редко; для Docker standalone обычно не нужен)
# PROJECT_ROOT="/app"

# --- Опционально: Telegram уведомления ---
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_* — см. настройки в админке
# SOCKS для исходящих вызовов к api.telegram.org (сайт + бот).
# Можно вставить ссылку из Telegram как есть (в кавычках):
# TELEGRAM_SOCKS_PROXY_URL="https://t.me/socks?server=HOST&port=PORT&user=USER&pass=PASS"
# Или tg://socks?... / socks5://user:pass@host:port
# Альтернативное имя: TELEGRAM_PROXY_SOCKS_URL

# --- Опционально: MAX bot integration ---
# MAX_BOT_TOKEN=""
# MAX_BOT_MODE="polling"
# MAX_BOT_WEBHOOK_URL="https://example.com/api/webhooks/max"
# MAX_BOT_WEBHOOK_SECRET=""
# MAX_SERVICE_SECRET=""
# MAX_SITE_URL="http://localhost:3000"

# --- Опционально: Яндекс.Карты (блок на сайте) ---
# NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""

# --- Опционально: CDEK, ЮKassa, почта и т.д. — настраиваются в админке или здесь ---
# APP_URL="https://innerhealth.ru"
# CDEK_CLIENT_ID=
# CDEK_CLIENT_SECRET=
# CDEK_USE_TEST=true

# --- Мульти-инстанс (несколько контейнеров за балансировщиком) ---
# Один и тот же ключ на всех инстансах; base64, 16/24/32 байт (например: openssl rand -base64 32)
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""
# Версия деплоя для защиты от version skew при rolling deploy
# DEPLOYMENT_VERSION="v1.0.0"

# --- Разработка ---
# DEBUG_ENABLED=true
# Дебаг корзины и виджета СДЭК (клиент: полный поток; сервер: все события)
# NEXT_PUBLIC_CART_DEBUG=true
# CART_DEBUG_ENABLED=true
