# =============================================================================
# Inner Health — переменные окружения для деплоя и разработки
# Скопируйте в .env.local и заполните значения. Не коммитьте .env.local.
# =============================================================================

# --- Обязательные для работы приложения ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
NEXTAUTH_SECRET="<минимум 32 символа, сгенерируйте: openssl rand -base64 32>"
NEXTAUTH_URL="https://your-domain.com"

# Публичный URL сайта (sitemap, robots, письма, редиректы)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Секретный путь к админке (по умолчанию /admin; задайте свой для безопасности)
ADMIN_SECRET_PATH="admin-panel"

# Ключ шифрования настроек в БД (SiteSetting). Сгенерируйте случайную строку.
SETTINGS_ENCRYPTION_KEY="<random-string-32-chars>"

# --- Опционально: Telegram уведомления ---
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_* — см. настройки в админке

# --- Опционально: Яндекс.Карты (блок на сайте) ---
# NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""

# --- Опционально: CDEK, ЮKassa, почта и т.д. — настраиваются в админке или здесь ---
# APP_URL="https://your-domain.com"
# CDEK_CLIENT_ID=
# CDEK_CLIENT_SECRET=
# CDEK_USE_TEST=true

# --- Мульти-инстанс (несколько контейнеров за балансировщиком) ---
# Один и тот же ключ на всех инстансах; base64, 16/24/32 байт (например: openssl rand -base64 32)
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""
# Версия деплоя для защиты от version skew при rolling deploy
# DEPLOYMENT_VERSION="v1.0.0"

# --- Разработка ---
# DEBUG_ENABLED=true
