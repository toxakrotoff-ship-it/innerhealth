{
  "name": "innerhealth",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev --webpack --port ${PORT:-3000}",
    "dev:turbopack": "node ./node_modules/next/dist/bin/next dev --turbo --port ${PORT:-3000}",
    "dev:webpack": "node ./node_modules/next/dist/bin/next dev --webpack --port ${PORT:-3000}",
    "build": "next build",
    "build:bot": "node scripts/build-bot.mjs",
    "start": "next start",
    "deploy:check": "npm run lint && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:adaptive": "vitest run --grep 'adaptive|overlap'",
    "test:playwright": "playwright test",
    "test:playwright:adaptive": "playwright test --grep='adaptive'",
    "test:playwright:ui": "playwright test --ui",
    "test:adaptive:check": "node scripts/test-adaptive-enhanced.js",
    "test:adaptive:verbose": "node scripts/test-adaptive-enhanced.js --verbose",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "favicon": "node scripts/generate-favicon.mjs",
    "seed:categories": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/seed-categories.ts",
    "seed:category-line-drafts": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' -r tsconfig-paths/register scripts/seed-category-line-drafts.ts",
    "create-admin": "ts-node scripts/create-admin-user.ts",
    "add-admin": "ts-node scripts/add-admin-user.ts",
    "import-tilda-leads": "ts-node scripts/import-tilda-leads.ts",
    "manage-users": "ts-node scripts/manage-users.ts",
    "security:hash-legacy-passwords": "ts-node scripts/hash-legacy-passwords.ts",
    "migrate:user-role": "ts-node scripts/migrate-add-user-role.ts",
    "backfill:slug": "ts-node scripts/backfill-product-slug.ts",
    "backfill:sanitize-text": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/backfill-product-text-sanitize.ts",
    "backfill:dimensions": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/backfill-product-dimensions-from-csv.ts",
    "sync:product-photos": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/sync-product-photos-from-tilda.ts",
    "tilda:download-images": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/download-tildacdn-images-to-local.ts",
    "telegram-bot": "ts-node --transpile-only -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/telegram-bot.ts",
    "max-bot:dev": "ts-node --transpile-only -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/max-bot.ts",
    "redirects:compare": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/compare-sites-redirects.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:status": "prisma migrate status",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:fix-history": "ts-node scripts/fix-migration-history.ts",
    "db:mark-applied": "ts-node scripts/mark-migrations-applied.ts",
    "deploy:preflight": "prisma generate && prisma migrate status",
    "start:with-migrate": "prisma migrate deploy && next start",
    "maintenance:cleanup-auth": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/cleanup-auth-tokens.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@maxhub/max-bot-api": "^0.2.2",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "fetch-socks": "^1.3.3",
    "iconoir-react": "^7.11.0",
    "libphonenumber-js": "^1.12.40",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "otplib": "^13.3.0",
    "pg": "^8.18.0",
    "postgres-date": "^2.1.0",
    "prisma": "^7.4.0",
    "prompts": "^2.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "undici": "^7.22.0",
    "validator": "^13.15.26",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.11",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.28.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.14.0",
    "jsdom": "^28.1.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.18.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
